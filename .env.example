# copy to .env.local and fill in — .env.local is gitignored, never commit real keys

# REQUIRED: rhea swap quote JWT (grab from multi-chain-lending src/services/api/swap.ts, boss-issued)
RHEA_JWT=

# Rango: public demo key below works but is shared/rate-limited; get a real key via Discord ticket
RANGO_API_KEY=c6381a79-2817-4602-83bf-6a641a409e32

# LiFi: optional but strongly recommended — without it you get 75 req/2h per IP (2-3 page refreshes).
# Free self-service key at portal.li.fi lifts it to 100 req/min
LIFI_API_KEY=

# Bungee/Socket: optional but recommended — the keyless public endpoint rate-limits aggressively.
# Free dedicated key (20 rps): Google form linked from docs.socket.tech "Get API Access"
SOCKET_API_KEY=

# SwapKit: register at dashboard.swapkit.dev; the SwapKit column stays "—" until set
SWAPKIT_API_KEY=
